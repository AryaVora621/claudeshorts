# Secrets / credentials — never commit these
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials*.json
client_secret*.json
token*.json

# Node
node_modules/
dist/
build/
*.log
npm-debug.log*
.pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/

# Runtime state & artifacts (regenerated, not source).
# NOTE: anchored with a leading slash so these only match the top-level runtime
# dirs — an unanchored `review/`/`publish/` also matches the source packages
# claudeshorts/review/ and claudeshorts/publish/ and silently drops them.
/data/
/review/
/publish/

# Media artifacts (large, regenerated)
/output/
/renders/
*.mp4
*.mov
*.wav
*.mp3
!assets/**

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
